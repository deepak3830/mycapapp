{
  "xsappname": "mycapapp",
  "scopes": [
            {
              "name": "$XSAPPNAME.Display",
              "description": "display"
            },

            {
              "name": "$XSAPPNAME.Edit",
              "description": "edit"
            },

            {
              "name": "$XSAPPNAME.Delete",
              "description": "delete",
              "granted-apps": [
                "$XSAPPNAME(application,business-partner)"
              ]
            },

            {
              "name": "$XSAPPNAME.Viewer",
              "description": "Viewer"
            },

            {
              "name": "$XSAPPNAME.Editor",
              "description": "Editor"
            }
  ],

  "attributes": [
            {
              "name": "spiderMan",
              "description": "Nank name that will control row level security",
              "valueType": "string"
            }
  ],
  "role-templates": [
            {
              "name": "Viewer",
              "description": "View all POs and employee data",
              "default-role-name": "Viewer: Authorized to Read All POs and Employee Data",
              "scope-references": [
                "$XSAPPNAME.Viewer"
              ],
              "attribute-references": [
                {
                  "name": "spiderMan"
                }
              ]
            },

            {
              "name": "Editor",
              "description": "Edit, delete POs and employee data",
              "scope-references": [
                "$XSAPPNAME.Editor",
                "$XSAPPNAME.Delete"
              ]
            }
  ],
  "authorities": [
    "$ACCEPT_GRANTED_AUTHORITIES"
  ],
  "oauth2-configuration": {
    "token-validity": 9000,
    "redirect-uris": [
              "https://*.cfapps.us10-001.hana.ondemand.com/login/callback",
              "https://*.cfapps.us10-003.hana.ondemand.com/login/callback"
    ],
    "credential-types": [
      "binding-secret",
      "x509"
    ]
  },
  "xsenableasyncservice": "true"
}
